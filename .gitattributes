# Normalize line endings
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts (keep CRLF)
*.ps1 text eol=crlf
*.bat text eol=crlf

# Docs
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf

# Binary / LFS
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.webp binary
*.tiff binary
*.pdf binary
