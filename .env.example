# Copy to .env and fill in real values. NEVER commit .env.
#
# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Use the asyncpg driver scheme for SQLAlchemy async engine.
# Example (local Docker Compose):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/office_hero

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate a new RS256 key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Paste entire PEM content on one line using \n to represent newlines, or use
# the multiline form shown below.  The leading/trailing quotes are required.
#
# JWT key variables hold the full PEM content with \n for newlines.
# DO NOT use real keys here — this file is committed to source control.
#
# Generate key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then export to single-line env var:
#   JWT_PRIVATE_KEY=$(awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem)
#
JWT_PRIVATE_KEY=replace-with-pem-contents-using-backslash-n-for-newlines
JWT_PUBLIC_KEY=replace-with-public-pem-contents-using-backslash-n-for-newlines
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ORS (OpenRouteService) ────────────────────────────────────────────────────
# API key from https://openrouteservice.org/dev/#/home
ORS_API_KEY=your_ors_api_key_here
ORS_BASE_URL=https://api.openrouteservice.org
