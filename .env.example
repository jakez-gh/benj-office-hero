# Frontend Environment Variables

# Local Development (default for pnpm dev)
# VITE_API_BASE_URL=http://localhost:8000
# Note: Vite proxy in vite.config.ts forwards /api → http://localhost:8000

# Fly.io Production Deployment
# VITE_API_BASE_URL=https://api.office-hero.fly.dev

# Feature Flags
# VITE_DEBUG_MODE=false
