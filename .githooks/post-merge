#!/usr/bin/env bash
# post-merge hook — auto-launch backend + frontend on deploy.
#
# Behaviour:
#   1. Kill any existing Office Hero servers (backend + admin-web)
#   2. Install dependencies (poetry + pnpm)
#   3. Start backend on a random available port
#   4. Start admin-web dev server on random port (Vite port: 0)
#   5. Write .server-ports file with actual ports for dev tooling
#
# Triggered automatically when:
#   - git merge (post-merge hook)
#   - git pull  (which runs merge internally)

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
PORTS_FILE="$ROOT/.server-ports"
PID_FILE="$ROOT/.server-pids"

# Color output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}🔄 post-merge hook: restarting servers...${NC}"

# ── Kill old servers ──────────────────────────────────────────────
if [[ -f "$PID_FILE" ]]; then
  echo -e "${YELLOW}⏹  Killing old server processes...${NC}"
  while IFS= read -r pid; do
    kill "$pid" 2>/dev/null || true
  done < "$PID_FILE"
  rm -f "$PID_FILE"
fi

# Also kill any orphan uvicorn / vite processes for this project
pkill -f "uvicorn office_hero" 2>/dev/null || true
pkill -f "vite.*admin-web" 2>/dev/null || true
sleep 1

# ── Install dependencies ──────────────────────────────────────────
echo "📦 Installing Python dependencies..."
cd "$ROOT"
poetry install --no-root --quiet 2>/dev/null || true

echo "📦 Installing Node dependencies..."
cd "$ROOT"
pnpm install --silent 2>/dev/null || true

# ── Find random available port ───────────────────────────────────
get_random_port() {
  python3 -c "
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.bind(('', 0))
port = s.getsockname()[1]
s.close()
print(port)
"
}

BACKEND_PORT=$(get_random_port)

# ── Start backend ────────────────────────────────────────────────
echo "🚀 Starting backend on port $BACKEND_PORT..."
cd "$ROOT"
poetry run uvicorn office_hero.main:app \
  --host 0.0.0.0 \
  --port "$BACKEND_PORT" \
  --reload \
  > "$ROOT/.backend.log" 2>&1 &
BACKEND_PID=$!

# ── Start admin-web ──────────────────────────────────────────────
echo "🚀 Starting admin-web (Vite, random port)..."
cd "$ROOT/apps/admin-web"
VITE_API_BASE_URL="http://localhost:$BACKEND_PORT" npx vite \
  --host 0.0.0.0 \
  > "$ROOT/.frontend.log" 2>&1 &
FRONTEND_PID=$!

# Wait for Vite to print port (it picks one randomly via port: 0)
sleep 3
FRONTEND_PORT=$(grep -oP 'localhost:\K[0-9]+' "$ROOT/.frontend.log" 2>/dev/null | head -1)
FRONTEND_PORT=${FRONTEND_PORT:-"(check .frontend.log)"}

# ── Write state files ────────────────────────────────────────────
echo "$BACKEND_PID" > "$PID_FILE"
echo "$FRONTEND_PID" >> "$PID_FILE"

cat > "$PORTS_FILE" << EOF
# Auto-generated by post-merge hook — $(date -Iseconds)
BACKEND_PORT=$BACKEND_PORT
BACKEND_PID=$BACKEND_PID
BACKEND_URL=http://localhost:$BACKEND_PORT
FRONTEND_PORT=$FRONTEND_PORT
FRONTEND_PID=$FRONTEND_PID
FRONTEND_URL=http://localhost:$FRONTEND_PORT
EOF

echo ""
echo -e "${GREEN}✅ Servers started!${NC}"
echo "   Backend:  http://localhost:$BACKEND_PORT  (PID $BACKEND_PID)"
echo "   Frontend: http://localhost:$FRONTEND_PORT  (PID $FRONTEND_PID)"
echo "   Ports:    $PORTS_FILE"
echo "   Logs:     .backend.log / .frontend.log"
