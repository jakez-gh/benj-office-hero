#!/usr/bin/env bash
# post-merge hook — ensure backend is available after git pull/merge

set -euo pipefail

HEALTH_URL="http://127.0.0.1:8000/health"

if command -v curl > /dev/null && curl -sSf "$HEALTH_URL" > /dev/null 2>&1; then
  echo "✅ Backend is already running on port 8000"
  exit 0
fi

echo "ℹ️  Backend not detected on port 8000; attempting startup..."

if [[ -x "scripts/start-backend.sh" ]]; then
  nohup bash scripts/start-backend.sh > /tmp/office-hero-backend.log 2>&1 &
elif [[ -f "scripts/start-backend.sh" ]]; then
  nohup bash scripts/start-backend.sh > /tmp/office-hero-backend.log 2>&1 &
else
  echo "⚠️  scripts/start-backend.sh not found; skipping backend auto-start"
  exit 0
fi

for _ in $(seq 1 20); do
  if command -v curl > /dev/null && curl -sSf "$HEALTH_URL" > /dev/null 2>&1; then
    echo "✅ Backend is running on port 8000"
    exit 0
  fi
  sleep 1
done

echo "⚠️  Backend did not become healthy within timeout"
exit 0
